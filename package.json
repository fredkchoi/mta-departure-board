{
  "name": "mta-departure-board",
  "version": "0.1.0",
  "description": "Real-time MTA subway departure board for Raspberry Pi",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc --project tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "gtfs-realtime-bindings": "^1.1.1",
    "long": "^5.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "concurrently": "^8.2.2",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
